# Backstage Records — variables de entorno (copiar a .env.local para dev)
# Todas son OPCIONALES en la preview: sin ellas, los formularios aceptan + loguean
# y el rate-limit es no-op. Activar email es decisión diferida del operador.

# Canonical / Open Graph
NEXT_PUBLIC_SITE_URL=https://brecords.unlimited-systems.net

# WhatsApp flotante (número sin +, con prefijo de país). Placeholder hasta tener el real.
NEXT_PUBLIC_WA_NUMBER=34600000000

# Email transaccional (Resend) — DIFERIDO. Sin RESEND_API_KEY, /api/contact acepta + loguea.
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=hola@brecords.unlimited-systems.net
# CONTACT_FROM_EMAIL=Backstage Records <noreply@brecords.unlimited-systems.net>

# Rate-limit (Upstash) — opcional. Sin estas vars, el limiter es no-op.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
